{
  "name": "shaggy-ai-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 127.0.0.1",
    "voice:companion": "bash services/voice-companion/start.sh",
    "snapshot:second-brain": "node scripts/build-second-brain-snapshot.mjs",
    "build": "node scripts/run-with-node-path.mjs next build --webpack",
    "start": "next start -H 127.0.0.1",
    "owner:open": "node scripts/open-local-owner.mjs",
    "lint": "node scripts/run-with-node-path.mjs eslint src next.config.ts eslint.config.mjs",
    "typecheck": "node scripts/run-with-node-path.mjs tsc --noEmit -p tsconfig.json",
    "test": "node --no-warnings --test --test-concurrency=1 \"tests/**/*.test.mjs\"",
    "verify:golden-frame": "node scripts/golden-frame-contract.mjs",
    "verify:security": "python3 scripts/verify-auth-hardening.py && python3 scripts/verify-auth-ui.py && python3 scripts/verify-knowledge-delete.py && python3 scripts/verify-embedding-lifecycle.py",
    "verify": "pnpm verify:golden-frame && pnpm test && pnpm verify:security && pnpm lint && pnpm typecheck && pnpm build"
  },
  "packageManager": "pnpm@11.10.0",
  "overrides": {
    "postcss": "^8.5.10"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@supabase/supabase-js": "^2.110.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "openai": "^4.0.0",
    "pdfjs-dist": "^4.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "recharts": "^3.9.2",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^20.19.43",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "d3-array": "^3.2.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
